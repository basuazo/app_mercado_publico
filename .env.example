# =============================================================================
# mp-oportunidades — variables de entorno
# Copia este archivo como .env y completa los valores. NUNCA subas .env al repo.
# =============================================================================

# --- Obligatorios ---

# Ticket de acceso a la API de Mercado Público (ChileCompra).
# Solicítalo en https://www.mercadopublico.cl/Modules/Comprador/Login.aspx
MP_TICKET=tu_ticket_aqui

# URL de conexión a Postgres. En producción usa Neon con sslmode=require.
# Ejemplo Neon: postgresql://usuario:clave@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Para la rama dev de Neon cambia el endpoint por el de la rama dev.
DATABASE_URL=postgresql://usuario:clave@host/dbname?sslmode=require

# Clave secreta para firmar las cookies de sesión (mínimo 32 caracteres aleatorios).
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_de_32_bytes

# Token que protege el endpoint POST /api/jobs/run (para cron-job.org u otro cron externo).
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JOBS_TOKEN=cambia_esto_por_un_token_aleatorio

# --- Opcionales con valores por defecto ---

# Solicitudes por segundo hacia la API (no cambiar sin revisar los ToS)
# RATE_LIMIT_RPS=1.0

# Presupuesto diario de requests (máximo real de la API: 10 000)
# API_DAILY_BUDGET=9000

# Tope de correos salientes por día (Brevo free: 300; dejar margen)
# EMAIL_DAILY_LIMIT=250

# --- SMTP (necesario para alertas por correo) ---
# Compatible con Brevo y Gmail (app password).
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=tu_usuario@brevo.com
# SMTP_PASSWORD=tu_clave_smtp
# SMTP_FROM=alertas@tudominio.cl

# --- Admin inicial (solo para el seed; se ignora después) ---
# ADMIN_EMAIL=admin@tudominio.cl
# ADMIN_PASSWORD=contraseña_segura_del_admin

# --- Tasas de cambio a CLP (actualizar periódicamente) ---
# TASA_UF=37000.0
# TASA_UTM=65000.0
# TASA_USD=950.0
# TASA_EUR=1030.0
